# Ved — environment configuration template.
#
# Copy this file to `.env` at the project root and fill in the values you
# need. Everything is commented with what it does and the default Ved
# uses when the key is absent.
#
#   Windows:   copy .env.example .env
#   Linux/macOS: cp .env.example .env

# ============================================================
# Voice / TTS pipeline (Piper)
# ============================================================
# Path to the Piper TTS voice model (.onnx) and its matching config
# (.onnx.json). These files are NOT shipped with the repo — they're
# gitignored because they're ~60 MB each. Download them once and
# point these keys at wherever you saved them. See README
# "Audio files — what they are and how to get them".
#
# Default in this repo's `.env` (Windows example):
voice_file=voice/assets/en_GB-southern_english_female-low.onnx
voice_json=voice/assets/en_GB-southern_english_female-low.onnx.json

# Wake / mode-switch sound effect. Small file, already tracked on GitHub
# at voice/assets/turbo_engine_short.wav. Set wake_sound= (empty) to
# disable the sound entirely.
wake_sound=voice/assets/turbo_engine_short.wav

# ============================================================
# Cloud LLM (OpenRouter) — optional
# ============================================================
# If your hardware can't host a local LLM (no GPU, too little RAM),
# set USE_CLOUD_API=true and paste your OpenRouter API key below.
# Every LLM call will then be routed to OpenRouter instead of Ollama.
#
# Get a free key at: https://openrouter.ai/keys
# Free model options: qwen/qwen-2.5-coder-7b-instruct,
#                     meta-llama/llama-3.3-70b-instruct:free,
#                     google/gemini-2.0-flash-exp:free
#
# Leave USE_CLOUD_API unset / false to run fully offline via Ollama.
# USE_CLOUD_API=true
OPENROUTER_MODEL=qwen/qwen-2.5-coder-7b-instruct
# API_KEY=sk-or-v1-paste-your-key-here

# ============================================================
# RAG vector-DB index
# ============================================================
# Path to the local vector-DB index file used for RAG retrieval.
# Ved creates this file automatically the first time you upload a
# document to a thread or to the global store — but you choose
# WHERE it lives by setting this key.
#
# Recommended:
#   - Windows:  DB_PATH=C:\path\to\your\VectorDB\index.bin
#   - Linux:    DB_PATH=/home/you/.local/share/ved/vectordb/index.bin
#   - macOS:    DB_PATH=/Users/you/.local/share/ved/vectordb/index.bin
#
# The parent directory is auto-created on first use, so you only
# need to set the path — no manual mkdir. Leave unset to use the
# project-local default (data/vectordb/index.bin).
# DB_PATH=C:\Users\you\VectorDB\index.bin

# ============================================================
# Telemetry
# ============================================================
# Ved records active-user sessions in data/telemetry.json so you can
# see how many people are currently using your deployment. State is
# stored LOCALLY only — nothing is sent over the network.
#
# Opt out entirely by setting:
# VED_TELEMETRY_DISABLED=true
#
# Adjust the idle window (seconds) before a silent session drops
# off the active-user count. Default is 300 (5 minutes).
# VED_TELEMETRY_TIMEOUT=300

# ============================================================
# Misc
# ============================================================
# Optional username for telemetry. Falls back to the OS env var
# USERNAME, then "anonymous".
# VED_USERNAME=alice
