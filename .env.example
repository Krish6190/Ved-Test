# Ved — environment configuration.
# Copy this file to `.env` and replace placeholder values with your own.

# Voice / TTS pipeline (Piper)
# Download voice files from https://rhasspy.github.io/piper-voices/ into voice/assets/.
voice_file=voice/assets/en_GB-southern_english_female-low.onnx
voice_json=voice/assets/en_GB-southern_english_female-low.onnx.json
wake_sound=voice/assets/turbo_engine_short.wav

# Cloud LLM (OpenRouter) — set to true and fill API_KEY to use cloud instead of local Ollama.
USE_CLOUD_API=false
OPENROUTER_MODEL=qwen/qwen-2.5-coder-7b-instruct
API_KEY=

# RAG vector-DB index path.
DB_PATH=data/vectordb/index.bin

# Telemetry — locally stored only. Set to true to disable.
VED_TELEMETRY_DISABLED=false
VED_TELEMETRY_TIMEOUT=900
VED_USERNAME=
