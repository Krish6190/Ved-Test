# Python virtual environments
.venv/
venv-linux/

# Python cache
__pycache__/
*.pyc

# Local environment file (contains secrets/API keys)
.env

# Heavy Piper TTS voice models (~60 MB each). Users download these themselves.
# See README "Audio files" for download instructions.
voice/assets/*.onnx
voice/assets/*.onnx.json

# Runtime data/state generated by Ved (keep data/*.py source files tracked)
data/*.json
data/plans/*.json
data/threads/
data/vectordb/

# Temporary test fixtures generated during pytest runs
tests/.tmp/

# IDE / tooling directories
.cursor/
.kimchi
